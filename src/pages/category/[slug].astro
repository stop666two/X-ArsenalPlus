---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, getCategorySlug, getCategoryBySlug } from '../../lib/constants';

export async function getStaticPaths() {
  return CATEGORIES.map(c => ({ params: { slug: getCategorySlug(c) } }));
}

const { slug } = Astro.params;
const categoryName = getCategoryBySlug(slug);

if (!categoryName) {
  return Astro.redirect('/');
}

const allSoftware = await getCollection('software');
const software = allSoftware
  .filter(s => s.data.categories.includes(categoryName))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`${categoryName} 软件`} description={`X-ArsenalPlus 收录的所有 ${categoryName} 类软件`}>
  <nav class="breadcrumb">
    <a href="/">首页</a>
    <span>/</span>
    <span class="current">{categoryName}</span>
  </nav>

  <h1 class="page-title">📂 {categoryName}</h1>
  <p class="page-subtitle">共收录 {software.length} 款软件</p>

  {software.length === 0 ? (
    <div class="empty-state">
      <div class="icon">📭</div>
      <p>该分类暂无软件</p>
    </div>
  ) : (
    <div class="software-grid">
      {software.map(s => <SoftwareCard software={s} />)}
    </div>
  )}

  <div class="back-link">
    <a href="/" class="btn">← 返回首页</a>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent-primary); }
  .breadcrumb .current { color: var(--text-primary); }
  .page-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .page-subtitle {
    color: var(--text-muted);
    margin-bottom: 32px;
  }
  .software-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .back-link {
    margin-top: 40px;
  }
  @media (max-width: 768px) {
    .software-grid { grid-template-columns: 1fr; }
  }
</style>
