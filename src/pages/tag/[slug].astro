---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
const allSoftware = await getCollection('software');
const tagsSet = new Set<string>();
for (const s of allSoftware) {
  for (const t of (s.data.tags || [])) {
    const slug = t.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    if (slug.length > 0) {
      tagsSet.add(slug);
    }
  }
}
return [...tagsSet].map(tag => ({ params: { slug: tag } }));
}

const { slug } = Astro.params;

const allSoftware = await getCollection('software');
const software = allSoftware
  .filter(s => (s.data.tags || []).some(t => t.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') === slug))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagRaw = (software[0]?.data.tags || []).find(
  t => t.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') === slug
) || slug;
---

<BaseLayout title={`标签: ${tagRaw}`} description={`X-ArsenalPlus 中标记为 ${tagRaw} 的所有软件`}>
  <nav class="breadcrumb">
    <a href="/">首页</a>
    <span>/</span>
    <span class="current">🏷️ {tagRaw}</span>
  </nav>

  <h1 class="page-title">🏷️ {tagRaw}</h1>
  <p class="page-subtitle">共找到 {software.length} 款含有此标签的软件</p>

  {software.length === 0 ? (
    <div class="empty-state">
      <div class="icon">📭</div>
      <p>该标签暂无软件</p>
    </div>
  ) : (
    <div class="software-grid">
      {software.map(s => <SoftwareCard software={s} />)}
    </div>
  )}

  <div class="back-link">
    <a href="/" class="btn">← 返回首页</a>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent-primary); }
  .breadcrumb .current { color: var(--text-primary); }
  .page-title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .page-subtitle {
    color: var(--text-muted);
    margin-bottom: 32px;
  }
  .software-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .back-link { margin-top: 40px; }
  @media (max-width: 768px) {
    .software-grid { grid-template-columns: 1fr; }
  }
</style>
