---
import BaseLayout from '../layouts/BaseLayout.astro';
import SoftwareCard from '../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, getCategorySlug } from '../lib/constants';

const allSoftware = await getCollection('software');
const sorted = allSoftware.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = sorted.slice(0, 20);
const topDownloads = [...sorted].sort((a, b) => (b.data.download_count || 0) - (a.data.download_count || 0)).slice(0, 10);

const allTags = new Map<string, number>();
for (const s of allSoftware) {
  for (const t of (s.data.tags || [])) {
    allTags.set(t, (allTags.get(t) || 0) + 1);
  }
}
const topTags = [...allTags.entries()].sort((a, b) => b[1] - a[1]).slice(0, 15);
---

<BaseLayout title="首页" description="X-ArsenalPlus — 软件军械库，精准、安全、多源的跨平台软件下载服务">
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">⚔️ X-ArsenalPlus <span class="hero-sub">软件军械库</span></h1>
      <p class="hero-desc">为 Windows / macOS / Linux 用户提供精准、安全、多源的软件下载服务。<br/>纯静态 · 无后端 · 无注册 · 打开即用</p>
      <div class="hero-actions">
        <a href="/ranking/" class="btn btn--primary btn--lg">🏆 热门排行</a>
        <a href="https://github.com/stop666two/X-ArsenalPlus/issues/new?template=submit-software.yml" target="_blank" class="btn btn--lg">📦 提交软件</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat-card">
        <span class="stat-num">{allSoftware.length}+</span>
        <span class="stat-label">收录软件</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">3</span>
        <span class="stat-label">覆盖平台</span>
      </div>
      <div class="stat-card">
        <span class="stat-num">{CATEGORIES.length}</span>
        <span class="stat-label">分类</span>
      </div>
    </div>
  </section>

  <section class="categories-section">
    <h2 class="section-title"><span class="icon">📂</span> 分类浏览</h2>
    <div class="categories-grid">
      {CATEGORIES.map(c => (
        <a href={`/category/${getCategorySlug(c)}/`} class="category-card">
          <span class="category-name">{c}</span>
          <span class="category-count">{allSoftware.filter(s => s.data.categories.includes(c)).length} 款</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title"><span class="icon">🆕</span> 最新收录</h2>
    <div class="software-grid" id="latest-grid">
      {latest.map(s => (
        <div class="grid-item" data-platforms={s.data.platforms.join(',')}>
          <SoftwareCard software={s} />
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title"><span class="icon">🏆</span> 热门 Top 10</h2>
    <div class="software-grid" id="top-grid">
      {topDownloads.map((s, i) => (
        <div class="grid-item" data-platforms={s.data.platforms.join(',')}>
          <SoftwareCard software={s} featured={i === 0} />
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-title"><span class="icon">🏷️</span> 热门标签</h2>
    <div class="tags-cloud">
      {topTags.map(([tag, count]) => (
        <a href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '')}/`} class="tag-pill">
          {tag} <span class="tag-count">{count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const url = new URL(location.href);
  const platform = url.searchParams.get('platform');

  if (platform && ['windows', 'macos', 'linux'].includes(platform)) {
    document.querySelectorAll('.grid-item').forEach(el => {
      const platforms = (el as HTMLElement).dataset.platforms?.split(',') || [];
      (el as HTMLElement).style.display = platforms.includes(platform) ? '' : 'none';
    });

    const indicator = document.createElement('div');
    indicator.className = 'platform-indicator';
    const names: Record<string, string> = { windows: 'Windows', macos: 'macOS', linux: 'Linux' };
    indicator.innerHTML = `当前筛选: <strong>${names[platform]}</strong> 平台 · <a href="/">清除筛选</a>`;
    const grid = document.getElementById('latest-grid');
    if (grid) grid.before(indicator);
  }
</script>

<style>
  .hero {
    text-align: center;
    padding: 64px 0 48px;
  }
  .hero-title {
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
  }
  .hero-sub {
    color: var(--accent-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-left: 12px;
    padding: 2px 10px;
    border: 1px solid rgba(88, 166, 255, 0.3);
    border-radius: var(--radius-sm);
    vertical-align: middle;
  }
  .hero-desc {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 32px;
    line-height: 1.8;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 48px;
  }
  .hero-stats {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-lg);
    padding: 20px 36px;
    text-align: center;
    min-width: 140px;
  }
  .stat-num {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--accent-primary);
  }
  .stat-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
  .categories-section {
    margin-top: 16px;
  }
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 40px;
  }
  .category-card {
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    padding: 16px;
    text-align: center;
    transition: all 0.2s;
  }
  .category-card:hover {
    border-color: var(--accent-primary);
    background: var(--bg-card-hover);
  }
  .category-name {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text-primary);
  }
  .category-count {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 4px;
  }
  .software-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  .platform-indicator {
    font-size: 0.875rem;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-md);
    padding: 8px 16px;
    margin-bottom: 16px;
  }
  .platform-indicator a {
    color: var(--accent-primary);
    margin-left: 8px;
  }
  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 14px;
    font-size: 0.8125rem;
    border-radius: 999px;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-primary);
    color: var(--text-secondary);
    transition: all 0.15s;
  }
  .tag-pill:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }
  .tag-count {
    font-size: 0.6875rem;
    color: var(--text-muted);
    background: var(--bg-primary);
    padding: 1px 6px;
    border-radius: 999px;
  }
  @media (max-width: 768px) {
    .hero-title {
      font-size: 1.75rem;
    }
    .hero-sub {
      display: inline-block;
      margin-left: 0;
      margin-top: 8px;
    }
    .software-grid {
      grid-template-columns: 1fr;
    }
    .categories-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
